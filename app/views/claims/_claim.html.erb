<div class="bg-white shadow rounded-lg p-6 mb-4">
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    <div class="space-y-2">
      <div class="flex items-center">
        <span class="text-gray-600 font-medium w-32">Policy Number:</span>
        <span class="text-gray-800"><%= claim.policy %></span>
      </div>
      <div class="flex items-center">
        <span class="text-gray-600 font-medium w-32">Email:</span>
        <span class="text-gray-800"><%= claim.email %></span>
      </div>
      <div class="flex items-center">
        <span class="text-gray-600 font-medium w-32">Age:</span>
        <span class="text-gray-800"><%= claim.age.age %></span>
      </div>
    </div>

    <div class="space-y-2">
      <div class="flex items-center">
        <span class="text-gray-600 font-medium w-32">Trip Type:</span>
        <span class="text-gray-800"><%= claim.trip_type&.one_way? ? "One-way" : "Round-trip" %></span>
      </div>
      <div class="flex items-center">
        <span class="text-gray-600 font-medium w-32">Start Date:</span>
        <span class="text-gray-800"><%= claim.trip_start_date&.strftime('%d %B %Y') %></span>
      </div>
      <div class="flex items-center">
        <span class="text-gray-600 font-medium w-32">End Date:</span>
        <span class="text-gray-800"><%= claim.trip_end_date&.strftime('%d %B %Y') %></span>
      </div>
    </div>

    <div class="space-y-2">
      <div class="flex items-center">
        <span class="text-gray-600 font-medium w-32">Excess Amount:</span>
        <span class="text-gray-800"><%= claim.excess&.excess.format %></span>
      </div>
      <div class="flex items-center">
        <span class="text-gray-600 font-medium w-32">Cruise Cover:</span>
        <span class="text-gray-800"><%= claim.has_cruise ? 'Yes' : 'No' %></span>
      </div>
      <div class="flex items-center">
        <span class="text-gray-600 font-medium w-32">Created:</span>
        <span class="text-gray-800"><%= claim.created_at.strftime('%d %B %Y') %></span>
      </div>
    </div>
  </div>

  <div class="mt-4 flex justify-end space-x-3">
    <%= link_to 'Update', edit_claim_path(claim), class: 'inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500' %>
  </div>
</div>