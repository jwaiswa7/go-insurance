<%= form_with(model: claim, class: "contents", data: { controller: "claim-form" }) do |form| %>
  <% if claim.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(claim.errors.count, "error") %> prohibited this claim from being saved:</h2>

      <ul class="list-disc ml-6">
        <% claim.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mx-auto grid grid-cols-2 gap-4">
    <div class="space-y-2">
      <%= render "shared/select_field", 
          form: form,
          field_name: :trip_type_id,
          label_text: "Trip Type *",
          options: Configuration::SchemeType.all.map { |trip_type| [trip_type.one_way? ? "One Way" : "Return", trip_type.id] },
          placeholder: "Select trip type",
          required: true,
          multiple: false,
          data: { claim_form_target: "tripType" }
      %>
    </div>
    <div class="space-y-2">
      <%= render "shared/select_field", 
          form: form,
          field_name: :age_id,
          label_text: "Age *",
          options: Age.valid.map { |age| [age.age, age.id] },
          placeholder: "Select age",
          required: true,
          multiple: false,
          data: { claim_form_target: "age" }
      %>
    </div>
    <div class="space-y-2">
      <%= render "shared/select_field", 
          form: form,
          field_name: :excess_id,
          label_text: "Excess *",
          options: Configuration::Excess.all.map { |excess| [excess.excess.format, excess.id] },
          placeholder: "Select excess",
          required: true,
          multiple: false,
          data: { claim_form_target: "excess" }
      %>
    </div>
    <div class="space-y-2">
      <%= render "shared/select_field", 
          form: form,
          field_name: :policy,
          label_text: "Policy *",
          options: Claim::POLICY_OPTIONS,
          placeholder: "Select policy",
          required: true,
          multiple: false,
          data: { claim_form_target: "policy", action: "change->claim-form#setStartDate" }
      %>
    </div>
    <div class="space-y-2">
      <%= render "shared/form_field",
          form: form,
          field_type: :date_field,
          field_name: :trip_start_date,
          label_text: "Trip Start Date *",
          required: true,
          options: { min: Date.today },
          data: {
            claim_form_target: "startDate",
            action: "change->claim-form#setEndDate"
          }
      %>
    </div>
    <div class="space-y-2">
      <%= render "shared/form_field",
          form: form,
          field_type: :date_field,
          field_name: :trip_end_date,
          label_text: "Trip End Date *",
          required: true,
          options: { min: Date.today },
          data: {
            claim_form_target: "endDate"
          }
      %>
    </div>
    <div class="space-y-2">
      <%= render "shared/select_field", 
          form: form,
          field_name: :destinations,
          label_text: "Destinations",
          options: Destination.all.map { |dest| [dest.country, dest.id] },
          placeholder: "Select destinations",
          required: false,
          multiple: true,
          data: { claim_form_target: "destinations" }
      %>
    </div>
    <div class="space-y-2">
      <%= render "shared/form_field",
          form: form,
          field_type: :email_field,
          field_name: :email,
          label_text: "Email",
          required: false,
          data: { },
          options: {
            placeholder: "Enter email"
          }
      %>
    </div>
  </div>
  <div class="mt-4">
      <%= form.submit class: "w-full sm:w-auto rounded-md px-2 py-1 text-sm bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
    </div>
<% end %>